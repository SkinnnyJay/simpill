{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": ["test.ts", "scripts/**/*.js", "__tests__/**/*.ts"],
  "exclude": ["node_modules", "utils"]
}
