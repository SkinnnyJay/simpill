{
  "name": "@simpill/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Root package for @simpill: all utils are installed from GitHub (SkinnnyJay/<name>.utils). Run 'npm install' at repo root; works anywhere (CI, other machines). No local workspace required.",
  "scripts": {
    "clean": "bash scripts/monorepo-clean.sh",
    "sync:deps": "node scripts/monorepo-sync-deps.js",
    "use:local": "node scripts/use-local-utils-at-root.js && npm install --no-audit --no-fund",
    "install:all": "npm install --ignore-scripts",
    "verify:deps": "node scripts/monorepo-verify-deps.js",
    "verify": "npm run verify:deps",
    "utils:verify": "bash scripts/utils-verify-all.sh",
    "utils:prepare": "bash scripts/utils-prepare-all.sh",
    "utils:fix-metadata": "node scripts/utils-fix-repo-metadata.js",
    "utils:keywords": "node scripts/utils-set-npm-keywords.js",
    "github:topics": "node scripts/github-set-all-topics.js",
    "github:topics:repo": "bash scripts/github-set-repo-topics.sh",
    "github:repos-public": "bash scripts/github-set-repos-public.sh",
    "publish": "bash scripts/publish-all.sh",
    "build": "npx tsc --noEmit",
    "typecheck": "npx tsc --noEmit",
    "test": "npx vitest run",
    "test:unit": "npx vitest run --dir __tests__/unit",
    "test:integration": "npx vitest run --dir __tests__/integration",
    "test:e2e": "npx vitest run --dir __tests__/e2e",
    "test:smoke": "npx tsx test.ts"
  },
  "devDependencies": {
    "std-env": "^3.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3",
    "vite": "^6.4.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "glob": "^11.0.0"
  },
  "dependencies": {
    "@simpill/adapters.utils": "github:SkinnnyJay/adapters.utils",
    "@simpill/algorithms.utils": "github:SkinnnyJay/algorithms.utils",
    "@simpill/annotations.utils": "github:SkinnnyJay/annotations.utils",
    "@simpill/api.utils": "github:SkinnnyJay/api.utils",
    "@simpill/array.utils": "github:SkinnnyJay/array.utils",
    "@simpill/async.utils": "github:SkinnnyJay/async.utils",
    "@simpill/cache.utils": "github:SkinnnyJay/cache.utils",
    "@simpill/collections.utils": "github:SkinnnyJay/collections.utils",
    "@simpill/crypto.utils": "github:SkinnnyJay/crypto.utils",
    "@simpill/data.utils": "github:SkinnnyJay/data.utils",
    "@simpill/enum.utils": "github:SkinnnyJay/enum.utils",
    "@simpill/env.utils": "github:SkinnnyJay/env.utils",
    "@simpill/errors.utils": "github:SkinnnyJay/errors.utils",
    "@simpill/events.utils": "github:SkinnnyJay/events.utils",
    "@simpill/factories.utils": "github:SkinnnyJay/factories.utils",
    "@simpill/file.utils": "github:SkinnnyJay/file.utils",
    "@simpill/function.utils": "github:SkinnnyJay/function.utils",
    "@simpill/http.utils": "github:SkinnnyJay/http.utils",
    "@simpill/logger.utils": "github:SkinnnyJay/logger.utils",
    "@simpill/middleware.utils": "github:SkinnnyJay/middleware.utils",
    "@simpill/misc.utils": "github:SkinnnyJay/misc.utils",
    "@simpill/nextjs.utils": "github:SkinnnyJay/nextjs.utils",
    "@simpill/number.utils": "github:SkinnnyJay/number.utils",
    "@simpill/object.utils": "github:SkinnnyJay/object.utils",
    "@simpill/observability.utils": "github:SkinnnyJay/observability.utils",
    "@simpill/patterns.utils": "github:SkinnnyJay/patterns.utils",
    "@simpill/protocols.utils": "github:SkinnnyJay/protocols.utils",
    "@simpill/react.utils": "github:SkinnnyJay/react.utils",
    "@simpill/request-context.utils": "github:SkinnnyJay/request-context.utils",
    "@simpill/resilience.utils": "github:SkinnnyJay/resilience.utils",
    "@simpill/socket.utils": "github:SkinnnyJay/socket.utils",
    "@simpill/string.utils": "github:SkinnnyJay/string.utils",
    "@simpill/test.utils": "github:SkinnnyJay/test.utils",
    "@simpill/time.utils": "github:SkinnnyJay/time.utils",
    "@simpill/token-optimizer.utils": "github:SkinnnyJay/token-optimizer.utils",
    "@simpill/uuid.utils": "github:SkinnnyJay/uuid.utils",
    "@simpill/zod.utils": "github:SkinnnyJay/zod.utils",
    "@simpill/zustand.utils": "github:SkinnnyJay/zustand.utils"
  }
}
